        const payments = readJsonFile(paymentsFile);
        res.json({
            success: true,
            data: payments,
            count: payments.length
        });
    } catch (error) {
        res.status(500).json({
            success: false,
            message: 'خطأ في الخادم'
        });
    }
});

// 5. الحصول على تفاصيل دفعة محددة
app.get('/api/payments/:id', (req, res) => {
    try {
        const payments = readJsonFile(paymentsFile);
        const payment = payments.find(p => p.id === req.params.id);

        if (!payment) {
            return res.status(404).json({
                success: false,
                message: 'الدفعة غير موجودة'
            });
        }

        res.json({
            success: true,
            data: payment
        });
    } catch (error) {
        res.status(500).json({
            success: false,
            message: 'خطأ في الخادم'
        });
    }
});

// 6. تحديث حالة الدفعة
app.put('/api/payments/:id', (req, res) => {
    try {
        const { status } = req.body;
        const payments = readJsonFile(paymentsFile);
        const paymentIndex = payments.findIndex(p => p.id === req.params.id);

        if (paymentIndex === -1) {
            return res.status(404).json({
                success: false,
                message: 'الدفعة غير موجودة'
            });
        }

        payments[paymentIndex].status = status;
        payments[paymentIndex].updatedAt = new Date().toISOString();
        writeJsonFile(paymentsFile, payments);

        res.json({
            success: true,
            message: 'تم تحديث الدفعة بنجاح',
            data: payments[paymentIndex]
        });
    } catch (error) {
        res.status(500).json({
            success: false,
            message: 'خطأ في الخادم'
        });
    }
});

// 7. لوحة المراقبة - إحصائيات
app.get('/api/dashboard/stats', (req, res) => {
    try {
        const payments = readJsonFile(paymentsFile);
        const orders = readJsonFile(ordersFile);

        const stats = {
            totalOrders: orders.length,
            totalPayments: payments.length,
            pendingPayments: payments.filter(p => p.status === 'pending').length,
            completedPayments: payments.filter(p => p.status === 'completed').length,
            failedPayments: payments.filter(p => p.status === 'failed').length,
            totalAmount: payments.reduce((sum, p) => sum + (parseFloat(p.amount) || 0), 0)
        };

        res.json({
            success: true,
            data: stats
        });
    } catch (error) {
        res.status(500).json({
            success: false,
            message: 'خطأ في الخادم'
        });
    }
});

// 8. تنظيف البيانات (اختياري - حذف جميع البيانات)
app.post('/api/admin/clear-data', (req, res) => {
    try {
        const adminPassword = req.body.password;
        
        // كلمة سر بسيطة - غيّرها في الإنتاج
        if (adminPassword !== 'admin123') {
            return res.status(403).json({
                success: false,
                message: 'كلمة السر غير صحيحة'
            });
        }

        writeJsonFile(paymentsFile, []);
        writeJsonFile(ordersFile, []);

        res.json({
            success: true,
            message: 'تم حذف جميع البيانات'
        });
    } catch (error) {
        res.status(500).json({
            success: false,
            message: 'خطأ في الخادم'
        });
    }
});

