            loadStats();
            loadPayments();
            loadOrders();
        }, 5000);
        
        // تحميل أولي
        loadStats();
        loadPayments();
        loadOrders();
    </script>
</body>
</html>
    `);
});

// بدء الخادم
app.listen(PORT, () => {
    console.log(`
╔════════════════════════════════════════╗
║  🚀 خادم الدفع المحلي قيد التشغيل       ║
// ==================== نظام المصادقة ====================
function validateAdminAuth(req, res, next) {
    const authHeader = req.headers['authorization'];
    if (!authHeader) {
        return res.status(401).json({ success: false, message: 'غير مصرح' });
    }
    
    const [username, password] = Buffer.from(authHeader.split(' ')[1], 'base64').toString().split(':');
    
    if (username === ADMIN_USERNAME && password === ADMIN_PASSWORD) {
        next();
    } else {
        res.status(403).json({ success: false, message: 'بيانات دخول غير صحيحة' });
    }
}

// ==================== API للمنتجات ====================

// 1. الحصول على جميع المنتجات
app.get('/api/products', (req, res) => {
    try {
        const products = readJsonFile(productsFile, []);
        res.json({ success: true, data: products });
    } catch (error) {
        res.status(500).json({ success: false, message: 'خطأ في الخادم' });
    }
});

// 2. إضافة منتج جديد (في البداية) - محمي
app.post('/api/products', validateAdminAuth, upload.single('image'), (req, res) => {
    try {
        const { name, description, price, previous_price, discount, category } = req.body;
        const products = readJsonFile(productsFile, []);
        
        let image_url = '';
        if (req.file) {
            image_url = '/uploads/' + req.file.filename;
        }
        
        const newProduct = {
            id: products.length ? Math.max(...products.map(p => p.id)) + 1 : 1,
            name: name || 'منتج بدون اسم',
            description: description || '',
            price: parseFloat(price) || 0,
            previous_price: parseFloat(previous_price) || 0,
            discount: parseFloat(discount) || 0,
            category: category || '',
            image_url: image_url
        };
        
        // إضافة المنتج الجديد في البداية
        products.unshift(newProduct);
        writeJsonFile(productsFile, products);
        
        res.json({ success: true, message: 'تم إضافة المنتج بنجاح', data: newProduct });
    } catch (error) {
        console.error('خطأ:', error);
        res.status(500).json({ success: false, message: 'خطأ في الخادم', error: error.message });
    }
});

// 3. تعديل منتج - محمي
app.put('/api/products/:id', validateAdminAuth, upload.single('image'), (req, res) => {
    try {
        const productId = parseInt(req.params.id);
        const { name, description, price, previous_price, discount, category } = req.body;
        const products = readJsonFile(productsFile, []);
        
        const productIndex = products.findIndex(p => p.id === productId);
        if (productIndex === -1) {
            return res.status(404).json({ success: false, message: 'المنتج غير موجود' });
        }
        
        // تحديث البيانات
        products[productIndex].name = name || products[productIndex].name;
        products[productIndex].description = description || products[productIndex].description;
        products[productIndex].price = parseFloat(price) || products[productIndex].price;
        products[productIndex].previous_price = parseFloat(previous_price) || products[productIndex].previous_price;
        products[productIndex].discount = parseFloat(discount) || products[productIndex].discount;
        products[productIndex].category = category || products[productIndex].category;
        
        // تحديث الصورة إذا تم رفع صورة جديدة
        if (req.file) {
            // حذف الصورة القديمة
            if (products[productIndex].image_url && fs.existsSync(path.join(__dirname, products[productIndex].image_url))) {
                fs.unlinkSync(path.join(__dirname, products[productIndex].image_url));
            }
            products[productIndex].image_url = '/uploads/' + req.file.filename;
        }
        
        writeJsonFile(productsFile, products);
        
        res.json({ success: true, message: 'تم تحديث المنتج بنجاح', data: products[productIndex] });
    } catch (error) {
        console.error('خطأ:', error);
        res.status(500).json({ success: false, message: 'خطأ في الخادم', error: error.message });
    }
});

// 4. حذف منتج محدد - محمي
app.delete('/api/products/:id', validateAdminAuth, (req, res) => {
    try {
        const productId = parseInt(req.params.id);
        const products = readJsonFile(productsFile, []);
        
        const productIndex = products.findIndex(p => p.id === productId);
        if (productIndex === -1) {
            return res.status(404).json({ success: false, message: 'المنتج غير موجود' });
        }
        
        // حذف الصورة من الخادم
        if (products[productIndex].image_url && fs.existsSync(path.join(__dirname, products[productIndex].image_url))) {
            fs.unlinkSync(path.join(__dirname, products[productIndex].image_url));
        }
        
        const deletedProduct = products.splice(productIndex, 1)[0];
        writeJsonFile(productsFile, products);
        
        res.json({ success: true, message: 'تم حذف المنتج بنجاح', data: deletedProduct });
    } catch (error) {
        console.error('خطأ:', error);
        res.status(500).json({ success: false, message: 'خطأ في الخادم', error: error.message });
    }
});

// 5. حذف جميع المنتجات - محمي
app.delete('/api/products', validateAdminAuth, (req, res) => {
    try {
        const products = readJsonFile(productsFile, []);
        
        // حذف جميع الصور
        products.forEach(product => {
            if (product.image_url && fs.existsSync(path.join(__dirname, product.image_url))) {
                fs.unlinkSync(path.join(__dirname, product.image_url));
            }
        });
        
        writeJsonFile(productsFile, []);
        
        res.json({ success: true, message: 'تم حذف جميع المنتجات بنجاح' });
    } catch (error) {
        console.error('خطأ:', error);
        res.status(500).json({ success: false, message: 'خطأ في الخادم', error: error.message });
    }
});

// 6. تكرار منتج - محمي
app.post('/api/products/:id/duplicate', validateAdminAuth, (req, res) => {
    try {
        const productId = parseInt(req.params.id);
        const products = readJsonFile(productsFile, []);
        
        const productIndex = products.findIndex(p => p.id === productId);
        if (productIndex === -1) {
            return res.status(404).json({ success: false, message: 'المنتج غير موجود' });
        }
        
        const duplicatedProduct = {
            ...products[productIndex],
            id: Math.max(...products.map(p => p.id)) + 1,
            name: products[productIndex].name + ' (نسخة)'
        };
        
        // إضافة المنتج المكرر في البداية
        products.unshift(duplicatedProduct);
        writeJsonFile(productsFile, products);
        
        res.json({ success: true, message: 'تم تكرار المنتج بنجاح', data: duplicatedProduct });
    } catch (error) {
        console.error('خطأ:', error);
        res.status(500).json({ success: false, message: 'خطأ في الخادم', error: error.message });
    }
});

// 7. لوحة إدارة المنتجات - محمي
app.get('/admin-products', (req, res) => {
    res.send(adminProductsPage());
});

function adminProductsPage() {
    return `
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إدارة المنتجات</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        body { 
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .container { max-width: 1400px; }
        header { 
            background: white;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        .product-card { 
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            margin-bottom: 20px;
            transition: transform 0.3s;
        }
        .product-card:hover { transform: translateY(-5px); }
        .product-image { 
            width: 100%;
            height: 200px;
            object-fit: cover;
            background: #f0f0f0;
        }
        .product-body { padding: 15px; }
        .product-title { font-weight: bold; color: #333; margin-bottom: 10px; }
        .product-price { 
            color: #e74c3c;
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 10px;
        }
        .btn-group { 
            display: flex;
            gap: 5px;
            margin-top: 10px;
        }
        .btn-sm { 
            padding: 5px 10px;
            font-size: 12px;
        }
        .form-section {
            background: white;
            padding: 30px;
            border-radius: 10px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        .modal { background: rgba(0,0,0,0.5); }
        .loading { display: none; text-align: center; padding: 20px; }
        .loading.show { display: block; }
        .alert { margin-bottom: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>📦 إدارة المنتجات</h1>
            <p>أضف، عدّل، احذف، أو كرّر المنتجات</p>
            <button class="btn btn-danger btn-sm" onclick="logout()"><i class="fas fa-sign-out-alt"></i> تسجيل خروج</button>
        </header>

        <div id="alert-container"></div>

        <!-- نموذج إضافة/تعديل منتج -->
        <div class="form-section">
            <h3>
                <span id="form-title">➕ إضافة منتج جديد</span>
            </h3>
            <form id="product-form" enctype="multipart/form-data">
                <input type="hidden" id="product-id" />
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>اسم المنتج *</label>
                        <input type="text" class="form-control" id="name" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label>الفئة</label>
                        <input type="text" class="form-control" id="category" placeholder="إلكترونيات، ملابس، إلخ" />
                    </div>
                </div>

                <div class="mb-3">
                    <label>الوصف</label>
                    <textarea class="form-control" id="description" rows="3"></textarea>
                </div>

                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label>السعر الحالي *</label>
                        <input type="number" class="form-control" id="price" step="0.01" required />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>السعر السابق</label>
                        <input type="number" class="form-control" id="previous_price" step="0.01" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>الخصم (%)</label>
                        <input type="number" class="form-control" id="discount" step="0.01" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>الصورة</label>
                        <input type="file" class="form-control" id="image" accept="image/*" />
                    </div>
                </div>

                <div id="image-preview" style="margin-bottom: 15px;"></div>

                <div class="btn-group">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ</button>
                    <button type="button" class="btn btn-secondary" onclick="resetForm()"><i class="fas fa-redo"></i> إلغاء</button>
                </div>
            </form>
        </div>

        <!-- عمليات جماعية -->
        <div class="form-section">
            <h3>⚙️ عمليات</h3>
            <button class="btn btn-warning btn-sm" onclick="clearAllProducts()"><i class="fas fa-trash"></i> حذف جميع المنتجات</button>
            <button class="btn btn-info btn-sm" onclick="loadProducts()"><i class="fas fa-sync"></i> تحديث</button>
        </div>

        <!-- قائمة المنتجات -->
        <div class="form-section">
            <h3>📋 المنتجات</h3>
            <div class="loading show" id="loading">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">جاري التحميل...</span>
                </div>
                <p>جاري تحميل المنتجات...</p>
            </div>
            <div id="products-container" class="row"></div>
        </div>
    </div>

    <script>
        let authHeader = '';
        let editingProductId = null;

        // تسجيل الدخول
        function login() {
            const username = prompt('اسم المستخدم:');
            if (!username) return;
            
            const password = prompt('كلمة المرور:');
            if (!password) return;
            
            authHeader = 'Basic ' + btoa(username + ':' + password);
            localStorage.setItem('authHeader', authHeader);
            loadProducts();
        }

        // التحقق من المصادقة
        if (!localStorage.getItem('authHeader')) {
            login();
        } else {
            authHeader = localStorage.getItem('authHeader');
        }

        // تحميل المنتجات
        async function loadProducts() {
            try {
                const response = await fetch('/api/products');
                const result = await response.json();
                
                if (!result.success) {
                    showAlert('خطأ في تحميل المنتجات', 'danger');
                    return;
                }

                document.getElementById('loading').classList.remove('show');
                const container = document.getElementById('products-container');
                container.innerHTML = '';

                if (result.data.length === 0) {
                    container.innerHTML = '<div class="col-12"><p class="text-center">لا توجد منتجات حتى الآن</p></div>';
                    return;
                }

                result.data.forEach(product => {
                    const card = document.createElement('div');
                    card.className = 'col-md-6 col-lg-4';
                    card.innerHTML = '<div class="product-card"><img src="' + (product.image_url || 'https://via.placeholder.com/300') + '" class="product-image" alt="' + product.name + '" /><div class="product-body"><div class="product-title">' + product.name + '</div><div class="product-price">' + product.price + ' د.ك</div><small class="text-muted">' + (product.category || 'بدون فئة') + '</small><div class="btn-group"><button class="btn btn-primary btn-sm" onclick="editProduct(' + product.id + ')"><i class="fas fa-edit"></i> تعديل</button><button class="btn btn-success btn-sm" onclick="duplicateProduct(' + product.id + ')"><i class="fas fa-copy"></i> تكرار</button><button class="btn btn-danger btn-sm" onclick="deleteProduct(' + product.id + ')"><i class="fas fa-trash"></i> حذف</button></div></div></div>';
                    container.appendChild(card);
                });
            } catch (error) {
                console.error('خطأ:', error);
                showAlert('خطأ في التواصل مع الخادم', 'danger');
            }
        }

        // إضافة/تعديل منتج
        document.getElementById('product-form').addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData();
            formData.append('name', document.getElementById('name').value);
            formData.append('description', document.getElementById('description').value);
            formData.append('price', document.getElementById('price').value);
            formData.append('previous_price', document.getElementById('previous_price').value);
            formData.append('discount', document.getElementById('discount').value);
            formData.append('category', document.getElementById('category').value);
            
            const imageFile = document.getElementById('image').files[0];
            if (imageFile) {
                formData.append('image', imageFile);
            }

            try {
                const productId = document.getElementById('product-id').value;
                const method = productId ? 'PUT' : 'POST';
                const url = productId ? '/api/products/' + productId : '/api/products';

                const response = await fetch(url, {
                    method: method,
                    headers: { 'Authorization': authHeader },
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    showAlert(result.message, 'success');
                    resetForm();
                    loadProducts();
                } else {
                    showAlert(result.message, 'danger');
                    if (response.status === 401 || response.status === 403) {
                        localStorage.removeItem('authHeader');
                        login();
                    }
                }
            } catch (error) {
                console.error('خطأ:', error);
                showAlert('خطأ في الإرسال', 'danger');
            }
        });

        // تعديل منتج
        async function editProduct(id) {
            const response = await fetch('/api/products');
            const result = await response.json();
            const product = result.data.find(p => p.id === id);

            if (!product) {
                showAlert('لم يتم العثور على المنتج', 'danger');
                return;
            }

            document.getElementById('product-id').value = product.id;
            document.getElementById('name').value = product.name;
            document.getElementById('description').value = product.description;
            document.getElementById('price').value = product.price;
            document.getElementById('previous_price').value = product.previous_price;
            document.getElementById('discount').value = product.discount;
            document.getElementById('category').value = product.category;

            if (product.image_url) {
                document.getElementById('image-preview').innerHTML = '<img src="' + product.image_url + '" style="max-height: 150px;" />';
            }

            document.getElementById('form-title').textContent = '✏️ تعديل المنتج';
            editingProductId = id;

            document.querySelector('html, body').scrollTop = 0;
        }

        // حذف منتج
        async function deleteProduct(id) {
            if (!confirm('هل أنت متأكد من حذف هذا المنتج؟')) return;

            try {
                const response = await fetch('/api/products/' + id, {
                    method: 'DELETE',
                    headers: { 'Authorization': authHeader }
                });

                const result = await response.json();

                if (result.success) {
                    showAlert('تم حذف المنتج', 'success');
                    loadProducts();
                } else {
                    showAlert(result.message, 'danger');
                }
            } catch (error) {
                showAlert('خطأ في الحذف', 'danger');
            }
        }

        // تكرار منتج
        async function duplicateProduct(id) {
            try {
                const response = await fetch('/api/products/' + id + '/duplicate', {
                    method: 'POST',
                    headers: { 'Authorization': authHeader }
                });

                const result = await response.json();

                if (result.success) {
                    showAlert('تم تكرار المنتج', 'success');
                    loadProducts();
                } else {
                    showAlert(result.message, 'danger');
                }
            } catch (error) {
                showAlert('خطأ في التكرار', 'danger');
            }
        }

        // حذف جميع المنتجات
        async function clearAllProducts() {
            if (!confirm('⚠️ هل أنت متأكد من حذف جميع المنتجات؟ هذه العملية لا يمكن استرجاعها!')) return;

            try {
                const response = await fetch('/api/products', {
                    method: 'DELETE',
                    headers: { 'Authorization': authHeader }
                });

                const result = await response.json();

                if (result.success) {
                    showAlert('تم حذف جميع المنتجات', 'success');
                    loadProducts();
                } else {
                    showAlert(result.message, 'danger');
                }
            } catch (error) {
                showAlert('خطأ في الحذف', 'danger');
            }
        }

        // إعادة تعيين النموذج
        function resetForm() {
            document.getElementById('product-form').reset();
            document.getElementById('product-id').value = '';
            document.getElementById('form-title').textContent = '➕ إضافة منتج جديد';
            document.getElementById('image-preview').innerHTML = '';
            editingProductId = null;
        }

        // عرض رسالة تنبيه
        function showAlert(message, type) {
            const alert = document.createElement('div');
            alert.className = 'alert alert-' + type;
            alert.innerHTML = '<button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>' + message;
            document.getElementById('alert-container').appendChild(alert);

            setTimeout(() => {
                alert.remove();
            }, 5000);
        }

        // تسجيل الخروج
        function logout() {
            localStorage.removeItem('authHeader');
            location.reload();
        }

        // تحميل المنتجات عند فتح الصفحة
        loadProducts();
    </script>
</body>
</html>
`;
}

