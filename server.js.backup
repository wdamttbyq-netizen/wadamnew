        function getStatusText(status) {
            const statusMap = {
                'pending': 'معلق',
                'completed': 'مكتمل',
                'failed': 'فاشل',
                'paid': 'مدفوع',
                'shipped': 'مرسل',
                'delivered': 'تم التسليم'
            };
            return statusMap[status] || status;
